    {
      "parameters": {
        "jsCode": "// Carry forward audience metadata from the split batch\nconst configItems = $('Split Into Audiences').all();\nconst currentAudience = configItems[0]?.json || {};\nconst audienceName = currentAudience.name || 'Unknown';\nconst audienceShort = currentAudience.short || 'UNK';\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const members = item.json.members || [item.json];\n  \n  for (const member of members) {\n    const mergeFields = member.merge_fields || {};\n    const email = member.email_address || '';\n    const firstName = mergeFields.FNAME || '';\n    const lastName = mergeFields.LNAME || '';\n    const jobTitle = mergeFields.JOBTITLE || mergeFields.JOB_TITLE || mergeFields.MMERGE3 || '';\n    const company = mergeFields.COMPANY || mergeFields.MMERGE4 || '';\n    \n    // Extract UTM from source or tags\n    const source = member.source || '';\n    const tags = (member.tags || []).map(t => t.name).join(', ');\n    \n    // Parse UTM from signup source URL or merge fields\n    const utmSource = mergeFields.UTM_SOURCE || mergeFields.MMERGE5 || '';\n    const utmMedium = mergeFields.UTM_MEDIUM || mergeFields.MMERGE6 || '';\n    const utmCampaign = mergeFields.UTM_CAMPAIGN || mergeFields.MMERGE7 || '';\n    const utmContent = mergeFields.UTM_CONTENT || mergeFields.MMERGE8 || '';\n    const xSignup = mergeFields.X_SIGNUP || mergeFields.MMERGE9 || '';\n    \n    // Determine ad source\n    const adSource = utmSource.toLowerCase() === 'facebookads' ? 'TFM' : \n                     utmSource ? 'Other' : 'Unknown';\n    \n    // Classify newsletter from UTM campaign or audience\n    let newsletterClassified = audienceShort;\n    const utmLower = utmCampaign.toLowerCase();\n    if (utmLower.includes('cardiac') || utmLower.includes('[cardiac')) newsletterClassified = 'CW';\n    else if (utmLower.includes('imaging') || utmLower.includes('[imaging')) newsletterClassified = 'IW';\n    else if (utmLower.includes('digital health') || utmLower.includes('[digital')) newsletterClassified = 'DHW';\n    \n    // Count fields filled (name, lastname, jobtitle, company)\n    const fieldsFilled = [firstName, lastName, jobTitle, company].filter(f => f.trim() !== '').length;\n    const all4Complete = fieldsFilled === 4 ? 'Yes' : 'No';\n    \n    // Qualification logic\n    const nonQualifiedRoles = ['retired', 'disabled', 'patient', 'student', 'unemployed', 'n/a', 'none', 'homemaker'];\n    const jobLower = jobTitle.toLowerCase().trim();\n    const companyLower = company.toLowerCase().trim();\n    \n    let qualified = '';\n    if (fieldsFilled >= 3 && jobTitle.trim() !== '') {\n      const isNonQualified = nonQualifiedRoles.some(role => \n        jobLower.includes(role) || companyLower.includes(role)\n      );\n      qualified = isNonQualified ? 'FALSE' : 'TRUE';\n    }\n    // If insufficient fields, leave qualified blank (manual review)\n    \n    results.push({\n      json: {\n        audience: audienceName,\n        audience_short: audienceShort,\n        email: email,\n        first_name: firstName,\n        last_name: lastName,\n        job_title: jobTitle,\n        company: company,\n        qualified: qualified,\n        utm_campaign: utmCampaign,\n        utm_source: utmSource,\n        utm_medium: utmMedium,\n        utm_content: utmContent,\n        ad_source: adSource,\n        newsletter_classified: newsletterClassified,\n        fields_filled: fieldsFilled.toString(),\n        all_4_complete: all4Complete,\n        opt_in_date: member.timestamp_opt || '',\n        tags: tags,\n        x_signup: xSignup,\n        message: '',\n        last_checked: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn results;"
      },
