    {
      "parameters": {
        "jsCode": "// Aggregate stats across all processed items from the loop\nconst allItems = $('Classify Leads').all();\n\nlet totalProcessed = allItems.length;\nlet cwCount = 0, iwCount = 0, dhwCount = 0;\nlet cwQualified = 0, iwQualified = 0, dhwQualified = 0;\nlet tfmCount = 0;\nlet totalQualified = 0;\n\nfor (const item of allItems) {\n  const d = item.json;\n  const short = d.audience_short;\n  \n  if (short === 'CW') {\n    cwCount++;\n    if (d.qualified === 'TRUE') cwQualified++;\n  } else if (short === 'IW') {\n    iwCount++;\n    if (d.qualified === 'TRUE') iwQualified++;\n  } else if (short === 'DHW') {\n    dhwCount++;\n    if (d.qualified === 'TRUE') dhwQualified++;\n  }\n  \n  if (d.ad_source === 'TFM') tfmCount++;\n  if (d.qualified === 'TRUE') totalQualified++;\n}\n\nconst qualifiedRate = totalProcessed > 0 \n  ? Math.round((totalQualified / totalProcessed) * 100) \n  : 0;\n\nreturn [{\n  json: {\n    totalProcessed,\n    cwCount,\n    cwQualified,\n    iwCount,\n    iwQualified,\n    dhwCount,\n    dhwQualified,\n    tfmCount,\n    totalQualified,\n    qualifiedRate\n  }\n}];"
      },
